---
import Layout from '@/layouts/Layout.astro'
import FastfetchAbout from '@/components/Info/FastfetchAbout.astro'
import SshInteractive from '@/components/Info/SshInteractive.astro'
---

<Layout>
    <info-state data-page="ssh" data-cmd-status="idle" style="display: none;"
    ></info-state>
    <column class="tile initial" id="info-tile">
        <column class="tile-content">
            <SshInteractive />
            <FastfetchAbout />
        </column>
    </column>
</Layout>

<style is:global>
    :has(info-state[data-page='fastfetch']) #info-tile {
        background-color: var(--surface0-85);
    }
</style>

<script>
    import { canPlaySound, tapSequence } from '@/utils/keyboard'
    import { waitFor } from '@/utils/time'
    import { $ } from '@/utils/dom'
    import AppStateListener from '@/utils/state'
    import { setPromptTextNode } from '@/utils/cursor'
    import { ShellCommandElement } from '@/components/ShellCommand/ShellCommandElement'

    const yesButton = $<'button'>('#yes-button')
    const fingerprintButton = $<'button'>('#fingerprint-button')

    const infoState = $('info-state')
    const fastfetchCommand = $('#fastfetch') as ShellCommandElement
    const sshCommand = $('#ssh') as ShellCommandElement

    window.addEventListener('load', async () => {
        if (canPlaySound()) {
            infoState?.setAttribute('data-page', 'fastfetch')
            fastfetchCommand.focusPreCursor()
        } else {
            infoState?.setAttribute('data-page', 'ssh')
            sshCommand.focusPreCursor()
        }
    })

    new AppStateListener('info-state').on('data-page', async ({ value }) => {
        if (!value) return

        if (value === 'fastfetch') {
            await handleDisplayFastFetch()
        } else if (value === 'ssh') {
            await handleDisplaySsh()
        }
    })

    async function handleDisplayFastFetch() {
        fastfetchCommand.setStatus('idle').focusPreCursor()

        await tapSequence('fastfetch<CR>', {
            onType: setPromptTextNode,
        })
        await waitFor(250)

        fastfetchCommand.setStatus('complete').focusPostCursor()
    }

    async function handleDisplaySsh() {
        sshCommand.focusPreCursor().setStatus('running')
        yesButton?.focus()
    }

    async function continueInitial() {
        yesButton?.setAttribute('disabled', 'true')
        sshCommand.setStatus('complete').focusPostCursor()

        await tapSequence('clear<CR>', {
            onType: setPromptTextNode,
        })

        await waitFor(250)

        setPromptTextNode([])

        infoState?.setAttribute('data-page', 'fastfetch')
    }

    yesButton?.addEventListener('click', continueInitial)
    fingerprintButton?.addEventListener('click', continueInitial)
</script>
