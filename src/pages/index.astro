---
import Layout from '@/layouts/Layout.astro'
import Keyboard from '@/components/Keyboard.astro'
import Waybar from '@/components/Waybar.astro'
import { ScreenName } from '@/types/state'
import '@/styles/tiling.css'

import Splash from '@/tiles/Splash.astro'
import Info from '@/tiles/Info.astro'
import Showcase from '@/tiles/Showcase.astro'
import Links from '@/tiles/Links.astro'
import Opinions from '@/tiles/Opinions.astro'
---

<Layout>
    <app-state>
        <navigation-state
            data-screen={ScreenName.Splash}
            data-focus={ScreenName.Splash}></navigation-state>
        <info-state
            data-page="initial"
            data-focus="initial"
            data-timeline-slide="0"></info-state>
        <links-state data-focus="initial"></links-state>
    </app-state>
    <div id="wallpaper">
        <Keyboard />
    </div>
    <column id="screen">
        <Waybar />
        <div id="tiles">
            <Splash />
            <Info />
            <Showcase />
            <Links />
            <Opinions />
        </div>
    </column>
</Layout>

<style>
    #wallpaper {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        #keyboard {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
        }
    }

    #tiles {
        display: flex;
        flex-direction: row;
        width: 100%;
        height: 100%;
        opacity: 1;
        animation-name: none;
        gap: 1lh 2ch;
    }

    @media (max-width: 720px) {
        #tiles {
            flex-direction: column;
        }
    }

    #screen {
        position: absolute;
        padding: 1lh 2ch;
        inset: 0;
        overflow: hidden;
        display: flex;
        flex-grow: 1;
        flex-shrink: 0;
        flex-basis: 0;
        animation-name: place;
        animation-duration: 0.5s;
        animation-fill-mode: forwards;
        gap: 1lh 2ch;
    }
</style>
