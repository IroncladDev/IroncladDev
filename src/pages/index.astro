---
import Layout from '@/layouts/Layout.astro'
import FastfetchAbout from '@/components/Info/FastfetchAbout.astro'
import SshInteractive from '@/components/Info/SshInteractive.astro'
---

<Layout>
    <info-state data-page="ssh" data-cmd-status="idle" style="display: none;"
    ></info-state>
    <column class="tile initial" id="info-tile">
        <column class="tile-content">
            <SshInteractive />
            <FastfetchAbout />
        </column>
    </column>
</Layout>

<style>
    #info-tile {
        overflow-y: auto;
    }
</style>

<script>
    import { canPlaySound, tapSequence } from '@/utils/keyboard'
    import { waitFor } from '@/utils/time'
    import AppStateListener from '@/utils/state'
    import type { KeyInteraction } from '@/utils/keys'

    const yesButton: HTMLButtonElement = document.querySelector('#yes-button')!
    const fingerprintButton: HTMLButtonElement = document.querySelector(
        '#fingerprint-button',
    )!
    const resumeButton: HTMLButtonElement =
        document.querySelector('#resume-button')!
    const promptCursor: HTMLSpanElement =
        document.querySelector('#prompt-cursor')!
    const infoState: HTMLElement = document.querySelector('info-state')!

    new AppStateListener('info-state').on('data-page', async ({ value }) => {
        if (!value) return

        if (value === 'fastfetch') {
            await handleDisplayFastFetch()
        } else if (value === 'ssh') {
            await handleDisplaySsh()
        }
    })

    window.addEventListener('load', async () => {
        if (canPlaySound()) {
            infoState.setAttribute('data-page', 'fastfetch')
            insertCursor('pre-fastfetch-prompt')
        } else {
            infoState.setAttribute('data-page', 'ssh')
            insertCursor('pre-ssh-prompt')
        }
    })

    const getCommandText = () => {
        return promptCursor.previousElementSibling as HTMLSpanElement
    }

    const typedInteractionSequence = (seq: KeyInteraction[]) => {
        getCommandText().innerText = seq.map((s) => s.originalKey).join('')
    }

    const insertCursor = (id: string) => {
        const cursorElement = document.getElementById(id)!

        cursorElement.insertAdjacentElement('beforeend', promptCursor)
    }

    async function continueInitial() {
        yesButton.disabled = true
        await waitFor(250)
        infoState.setAttribute('data-cmd-status', 'complete')

        await tapSequence('clear<CR>', {
            onType: typedInteractionSequence,
        })

        await waitFor(250)

        getCommandText().innerText = ''

        infoState.setAttribute('data-cmd-status', 'idle')
        infoState.setAttribute('data-page', 'fastfetch')
    }

    yesButton.addEventListener('click', continueInitial)
    fingerprintButton.addEventListener('click', continueInitial)

    async function clearPrompt() {
        await tapSequence('clear<CR>', {
            onType: typedInteractionSequence,
        })

        await waitFor(250)

        getCommandText().innerText = ''
        infoState.setAttribute('data-cmd-status', 'idle')
    }

    async function handleDisplayFastFetch() {
        insertCursor('pre-fastfetch-prompt')

        if (infoState.getAttribute('data-cmd-status') === 'complete') {
            await clearPrompt()
        }

        infoState.setAttribute('data-cmd-status', 'idle')

        await tapSequence('fastfetch<CR>', {
            onType: typedInteractionSequence,
        })
        await waitFor(250)

        infoState.setAttribute('data-cmd-status', 'complete')
        insertCursor('post-fastfetch-prompt')

        resumeButton.focus()
    }

    async function handleDisplaySsh() {
        infoState.setAttribute('data-cmd-status', 'running')
        insertCursor('post-ssh-prompt')
        yesButton.focus()
    }
</script>
