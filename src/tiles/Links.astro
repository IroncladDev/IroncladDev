                    <div
                        is-="separator"
                        style="--separator-color: var(--blue-bg)"></div>
                    <a
                        href="https://signal.group/#CjQKIFso0Z5zIUiTAcueMbLgezhczQ19cO-STQK6LZfDbKzqEhAR2_vENgBwvx1qdTHpDnR-"
                        target="_blank"
                        rel="noreferrer">
                        signal.group/#CjQKIFso0Z5zIUiTAcueMbLgezhczQ19cO-STQK6LZfDbKzqEhAR2_vENgBwvx1qdTHpDnR-
