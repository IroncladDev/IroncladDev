</div>

<style>
    #links-prompt {
        display: none;

        html:has(links-state[data-focus='initial']) & {
            display: flex;
        }
    }

    #links-content {
        display: none;

        html:has(links-state[data-focus='links']) & {
            display: flex;
        }

        max-width: 60ch;
    }

    li {
        display: flex;
        gap: 1ch;
    }

    blockquote::before {
        background-color: var(--blue-fg);
    }
</style>

<script>
    import { tapSequence } from '@/utils/keyboard'
    import { waitFor } from '@/utils/time'
    import { ScreenName } from '@/types/state'
    import AppStateListener from '@/utils/state'

    const linksCursor: HTMLSpanElement =
        document.querySelector('#links-cursor')!
    const linksPrompt: HTMLSpanElement =
        document.querySelector('#links-prompt')!
    const postLinksPrompt: HTMLSpanElement =
        document.querySelector('#post-links-prompt')!
    const linksState: HTMLElement = document.querySelector('links-state')!

    const getPromptText = () => {
        return linksCursor.previousElementSibling as HTMLSpanElement
    }

    new AppStateListener('navigation-state')
        .on('data-focus', ({ value }) => {
            if (value !== ScreenName.Links) return

            handleShowLinks()
        })
        .on('data-screen', ({ value }) => {
            if (value !== ScreenName.Links) return

            linksState.setAttribute('data-focus', 'initial')
            linksPrompt.insertAdjacentElement('beforeend', linksCursor)
            getPromptText().innerText = ''
        })

    async function handleShowLinks() {
        await waitFor(250, window.navController)
        await tapSequence('links<CR>', {
            onType(seq) {
                getPromptText().innerText = seq
                    .map((s) => s.originalKey)
                    .join('')
            },
            signal: window.navController.signal,
        })
        linksState.setAttribute('data-focus', 'links')
        postLinksPrompt.insertAdjacentElement('beforeend', linksCursor)
    }
</script>
