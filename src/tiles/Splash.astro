---
import { ScreenName } from '@/types/state'
---

<div screen-={ScreenName.Splash} class="tile" id="tile-splash">
    <column id="content" gap-="1">
        <column>
            <button id="button" autofocus>&gt; Enter ironclad.sh &lt;</button>
            <p>Click or press a key to continue</p>
        </column>
        <span id="prompt">
            <span id="host">~/</span>
            <span id="cmd"></span>
            <span is-="spinner" variant-="block"></span>
        </span>
    </column>
</div>

<style>
    #content {
        text-align: left;
        justify-content: center;
        max-width: var(--max-reading-width);
    }
    #prompt {
        display: inline-flex;
        #host {
            color: var(--blue-fg);
            padding-right: 1ch;
        }
    }
    #tile-splash {
        display: flex;
        flex-direction: column;
        width: 100%;
        height: 100%;
        opacity: 1;
        gap: 1lh;
        align-items: center;
        justify-content: center;
        animation-name: none;
        background-color: var(--surface0-75);
    }
</style>

<script>
    import { tapSequence } from '@/utils/keyboard'
    import { waitFor } from '@/utils/time'

    const button = document.querySelector('#button') as HTMLButtonElement

    let isProceeding = false
    let typedText = ''

    async function proceed() {
        if (isProceeding) return

        isProceeding = true
        await tapSequence('ssh ironclad.sh<CR>', (seq) => {
            const cmdText = document.querySelector('#cmd') as HTMLSpanElement

            typedText += seq.originalKey
            cmdText.innerText = typedText
        })
        await waitFor(500)
        window.dispatchEvent(new Event('hashchange'))
    }

    button.addEventListener('click', proceed)
    button.addEventListener('keyup', proceed)
</script>
