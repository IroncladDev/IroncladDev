---
import Keyboard from '@/components/Keyboard.astro'
import Waybar from '@/components/Waybar.astro'

import '@/styles/global.css'
import '@/styles/tiling.css'

const title = 'IroncladDev'
const description =
    "I'm IroncladDev, a Texas-based software engineer who aims to produce and share great software with the world"
---

<!doctype html>
<html lang="en-us" data-webtui-theme="osmium">
    <head>
        <title>IroncladDev</title>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1, viewport-fit=cover"
        />

        <!-- Icons -->
        <link rel="icon" type="image/svg+xml" href="/img/brand/svg/icon.svg" />
        <link rel="icon" type="image/png" href="/img/brand/png/icon@20.png" />

        <!-- Other meta tags to insert in the head tag -->
        <slot name="head-meta" />

        <!-- Meta Title -->
        <meta property="og:title" content={title} />
        <meta name="twitter:title" content={title} />
        <!-- Meta Description -->
        <meta name="description" content={description} />
        <meta property="og:description" content={description} />
        <meta name="twitter:description" content={description} />
        <!-- Meta Image -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta
            name="twitter:image"
            content="https://ironclad.sh/img/cover.png"
        />
        <meta property="og:image" content="https://ironclad.sh/img/cover.png" />
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:width" content="2560" />
        <meta property="og:image:height" content="1600" />
        <!-- Misc Metadata -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://ironclad.sh" />
        <meta name="twitter:site" content="@IroncladDev" />
        <meta name="twitter:creator" content="@IroncladDev" />
        <meta name="twitter:url" content="https://ironclad.sh" />
        <meta
            name="keywords"
            content="website, developer, neovim, ironclad, ironcladdev"
        />
        <meta name="theme-color" content="#1f1d2d" />
        <style>
            #wallpaper {
                position: absolute;
                inset: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                #keyboard {
                    position: absolute;
                    left: 50%;
                    transform: translateX(-50%);
                }
            }

            #screen {
                position: absolute;
                padding: 1lh 2ch;
                inset: 0;
                overflow: hidden;
                display: flex;
                flex-grow: 1;
                flex-shrink: 0;
                flex-basis: 0;
                gap: 1lh 2ch;
            }

            @media (max-width: 480px) {
                #screen {
                    flex-direction: column-reverse;
                }
            }
        </style>
    </head>

    <body>
        <div id="wallpaper">
            <Keyboard />
        </div>
        <column id="screen">
            <Waybar />
            <column id="tiles-container">
                <div id="tiles">
                    <slot />
                </div>
                <slot name="footer" />
            </column>
        </column>
    </body>
</html>
